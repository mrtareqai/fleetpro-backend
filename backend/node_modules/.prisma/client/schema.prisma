generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_URL")
}

model Tenant {
  id             String   @id
  serverId       String   @unique
  name           String
  ownerName      String
  phone          String
  email          String
  telegramChatId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  users         AppUser[]
  vehicles      Vehicle[]
  reservations  Reservation[]
  tickets       Ticket[]
  drivers       Driver[]
  activityLogs  ActivityLog[]
  roles         AppRole[]
  routes        TripRoute[]
  branches      Branch[]
  agents        Agent[]
  trips         Trip[]
  transactions  Transaction[]
  expenses      Expense[]
  notifications Notification[]
}

model AppUser {
  id                 String  @id
  tenantId           String?
  tenant             Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  username           String  @unique
  password           String
  role               String
  mustChangePassword Boolean @default(false)
  isActive           Boolean @default(true)
  displayName        String
}

model Vehicle {
  id              Int      @id @default(autoincrement())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  model           String
  manufactureDate DateTime
  plateNumber     String
  baseNumber      String
  cardNumber      String
  issueDate       DateTime
  expiryDate      DateTime
  status          String   @default("active")

  trips    Trip[]
  expenses Expense[]
}

model Reservation {
  id          Int      @id @default(autoincrement())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientName  String
  pickupDate  DateTime
  returnDate  DateTime
  destination String
  status      String   @default("active")
}

model Ticket {
  id            String   @id
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketNumber  String
  passengerName String
  trip          String
  tripDate      DateTime
  seatNumber    String
  time          String
  phone         String
  assignedUser  String
  issueDate     DateTime
  destination   String
  status        String   @default("active")
}

model Driver {
  id            Int      @id @default(autoincrement())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  licenseNumber String
  licenseExpiry DateTime
  status        String   @default("active")

  trips Trip[]
}

model ActivityLog {
  id          String   @id
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String?
  action      String
  description String
  timestamp   DateTime
  ipAddress   String?
  type        String
  userName    String?
  icon        String?
}

model BlockedIp {
  ipAddress      String    @id
  failedAttempts Int       @default(0)
  isBlocked      Boolean   @default(false)
  blockedUntil   DateTime?
  reason         String?
  createdAt      DateTime  @default(now())
}

model AppRole {
  id          String  @id
  name        String
  nameAr      String
  tenantId    String?
  tenant      Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions Json
}

model TripRoute {
  id                Int     @id @default(autoincrement())
  tenantId          String
  tenant            Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  originCity        String
  destinationCity   String
  stopsCount        Int     @default(0)
  estimatedDuration Int
  basePrice         Float
  branchId          Int?
  branch            Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  agentId           Int?
  agent             Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)
  status            String  @default("active")

  trips Trip[]

  @@map("TripRoute") // 🔥 هذا السطر المهم
}

model Branch {
  id       Int     @id @default(autoincrement())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  location String
  isActive Boolean @default(true)

  agents   Agent[]
  routes   TripRoute[]
  expenses Expense[]
}

model Agent {
  id         Int     @id @default(autoincrement())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  phone      String
  branchId   Int?
  branch     Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  commission Float   @default(0.0)
  isActive   Boolean @default(true)

  routes TripRoute[]
}

model Trip {
  id             Int       @id @default(autoincrement())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  routeId        Int
  route          TripRoute @relation(fields: [routeId], references: [id], onDelete: Restrict)
  vehicleId      Int
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driverId       Int
  driver         Driver    @relation(fields: [driverId], references: [id], onDelete: Restrict)
  departureTime  DateTime
  totalSeats     Int
  availableSeats Int
  status         String    @default("scheduled")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type        String
  amount      Float
  category    String
  date        DateTime
  description String
}

model Expense {
  id          Int      @id @default(autoincrement())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount      Float
  category    String
  date        DateTime
  description String
  vehicleId   Int?
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  branchId    Int?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
}

model Notification {
  id        Int      @id @default(autoincrement())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("system")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
